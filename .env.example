# Copy to `.env` and fill in locally. Do not commit `.env`.

# --- Supabase (Dashboard → Project Settings → API) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# --- Google AI (AI Studio) — client-side for Gemini Live / vision helpers ---
VITE_GEMINI_API_KEY=
# Optional override; default is Gemini Live preview model
# VITE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# --- Public site URL (build-time canonical / og:url; optional) ---
# VITE_SITE_URL=https://your-domain.com
